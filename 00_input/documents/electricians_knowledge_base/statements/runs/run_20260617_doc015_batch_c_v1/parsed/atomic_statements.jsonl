{"statement_id": "doc_015_chunk_0020_stmt_003", "statement": "До переключения байпаса в положение от инвертора нагрузка резервной группы еще питается напрямую от сети.", "statement_type": "definition", "roles": ["electrician", "installer"], "topic": "installation_process", "source_document_id": "doc_015", "source_file": "ЭЛК_3_Базовые_знания_Описание_этапов_монтажа_ред1_9.docx", "source_chunk_id": "doc_015_chunk_0020", "section_path": ["ЭЛК-Базовые знания", "Этапы монтажа", "3) Пуск и наладка ИБП"], "source_quote": "При этом нагрузка (группа резерва) еще питается напрямую от сети.", "source_quote_is_exact": true, "related_image_ids": [], "visual_review_required": false, "risk_level": "safety_critical", "confidence": "high", "review_status": "review_required", "scope": "Пуск и наладка ИБП", "condition": "До переключения байпаса в положение от инвертора", "action": "", "object": "Нагрузка резервной группы", "normalized_terms": ["группа резерва", "сеть", "байпас"], "extraction_notes": ""}
