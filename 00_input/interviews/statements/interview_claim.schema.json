{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sveton.local/schemas/business_interviews/interview_claim.schema.json",
  "title": "Business interview source-backed claim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "claim_id",
    "claim",
    "claim_type",
    "source_interview_id",
    "source_file",
    "source_chunk_id",
    "speaker_label",
    "speaker_identity",
    "speaker_role",
    "speaker_mapping_confidence",
    "start_timestamp",
    "end_timestamp",
    "source_quote",
    "business_area",
    "target_outputs",
    "applicability_to_electricians_kb",
    "evidence_status",
    "confidence",
    "review_status",
    "review_flags",
    "notes"
  ],
  "properties": {
    "claim_id": {
      "type": "string",
      "pattern": "^interview_claim_[0-9]{6}$"
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "business_model_claim",
        "customer_segment_claim",
        "customer_pain",
        "value_proposition_claim",
        "sales_process_claim",
        "partner_model_claim",
        "product_claim",
        "positioning_claim",
        "marketing_message",
        "strategy_claim",
        "operational_claim",
        "risk_or_constraint",
        "objection",
        "recommended_response",
        "qualification_question",
        "sales_case",
        "open_question",
        "technical_claim_needs_confirmation"
      ]
    },
    "source_interview_id": {
      "type": "string",
      "pattern": "^interview_[0-9]{3}$"
    },
    "source_file": {
      "type": "string",
      "minLength": 1
    },
    "source_chunk_id": {
      "type": "string",
      "pattern": "^interview_[0-9]{3}_chunk_[0-9]{4}$"
    },
    "speaker_label": {
      "type": "string",
      "pattern": "^SPEAKER_[0-9]{2}$"
    },
    "speaker_identity": {
      "type": "string",
      "minLength": 1
    },
    "speaker_role": {
      "type": "string",
      "minLength": 1
    },
    "speaker_mapping_confidence": {
      "type": "string",
      "enum": [
        "confirmed",
        "likely",
        "low_confidence",
        "unreliable",
        "needs_mapping"
      ]
    },
    "start_timestamp": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"
    },
    "end_timestamp": {
      "type": "string",
      "pattern": "^[0-9]{2}:[0-9]{2}:[0-9]{2}$"
    },
    "source_quote": {
      "type": "string",
      "minLength": 1
    },
    "business_area": {
      "type": "string",
      "enum": [
        "business_model",
        "customer_segment",
        "customer_pain",
        "value_proposition",
        "positioning",
        "marketing",
        "sales_process",
        "objection_handling",
        "qualification",
        "partner_model",
        "product",
        "operations",
        "strategy",
        "risk",
        "service_model",
        "technical_context",
        "open_question"
      ]
    },
    "target_outputs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "business_kb",
          "sales_training",
          "manager_training",
          "website",
          "brochure",
          "presentation",
          "strategy",
          "sales_script",
          "objection_handling",
          "commercial_messaging",
          "content_bank",
          "electricians_kb",
          "review_only"
        ]
      }
    },
    "applicability_to_electricians_kb": {
      "type": "string",
      "enum": [
        "directly_relevant",
        "context_only",
        "needs_confirmation",
        "not_relevant"
      ]
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "source_backed",
        "speaker_opinion",
        "hypothesis",
        "example_case",
        "open_question",
        "needs_external_confirmation"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "extracted",
        "review_required",
        "approved",
        "rejected"
      ]
    },
    "review_flags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "speaker_mapping_required",
          "diarization_unreliable",
          "recognition_noise",
          "technical_confirmation_required",
          "marketing_claim_review",
          "strategy_claim_review",
          "price_or_guarantee_review",
          "contradiction_candidate",
          "low_confidence",
          "open_question",
          "public_use_review"
        ]
      }
    },
    "related_claim_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^interview_claim_[0-9]{6}$"
      },
      "default": []
    },
    "normalized_terms": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      },
      "default": []
    },
    "objection": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "objection_category",
        "customer_assumption",
        "recommended_response"
      ],
      "properties": {
        "objection_category": { "type": "string" },
        "customer_assumption": { "type": "string" },
        "recommended_response": { "type": "string" }
      },
      "default": null
    },
    "sales_case": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "customer_type",
        "problem_situation",
        "diagnosis_path",
        "proposed_action"
      ],
      "properties": {
        "customer_type": { "type": "string" },
        "problem_situation": { "type": "string" },
        "diagnosis_path": { "type": "string" },
        "proposed_action": { "type": "string" },
        "risk_or_caveat": { "type": "string", "default": "" }
      },
      "default": null
    },
    "discovery_question": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "question",
        "why_it_matters",
        "answer_changes"
      ],
      "properties": {
        "question": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "answer_changes": { "type": "string" }
      },
      "default": null
    },
    "open_question": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "question",
        "why_it_matters",
        "needed_validation"
      ],
      "properties": {
        "question": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "needed_validation": { "type": "string" },
        "possible_owner": { "type": "string", "default": "" }
      },
      "default": null
    },
    "notes": {
      "type": "string"
    }
  }
}
